# Reference template. Copy to badge-service/.env and fill in.
# (This file has no leading dot so it's committed; .env itself is gitignored.)

# Same MongoDB the Next app uses (see the project's root .env.local).
MONGODB_URI="mongodb+srv://...."
MONGODB_DB=olettrasocials

# Shared secret — must match BADGE_SERVICE_TOKEN in the Next app's .env.local.
# Leave empty for local dev to disable auth.
BADGE_SERVICE_TOKEN=change-me

# Optional overrides. Fonts are bundled in assets/fonts/ (Arimo + Cousine) and
# used by default, so you only set these to swap faces.
# BADGE_TEMPLATE_PATH=./assets/whiff_founder_badge_template.png
# BADGE_OUTPUT_DIR=./generated_badges
# BADGE_NUMBER_FONT=./assets/fonts/Arimo-Regular.ttf
# BADGE_HIDDEN_FONT=./assets/fonts/Cousine-Regular.ttf

# Gmail delivery — leave unset until you're ready. When both are set, badges
# are emailed automatically. GMAIL_APP_PASSWORD is a Google App Password
# (not your normal password): https://myaccount.google.com/apppasswords
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=
# GMAIL_FROM=you@gmail.com
